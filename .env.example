# ─── Google Gemini (required for AI post generation) ───
GEMINI_API_KEY="your_gemini_api_key_here"

# ─── LinkedIn OAuth App (required for posting) ───
LINKEDIN_CLIENT_ID="your_linkedin_app_client_id"
LINKEDIN_CLIENT_SECRET="your_linkedin_app_client_secret"

# ─── LinkedIn User Credentials (auto-filled via /connect-linkedin OAuth flow) ───
LINKEDIN_ACCESS_TOKEN="your_linkedin_access_token_here"
LINKEDIN_PERSON_URN="urn:li:person:your_person_urn_here"
