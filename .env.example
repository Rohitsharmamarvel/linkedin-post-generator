# ════════════════════════════════════════════════════════════════
# LinkedIn Content Studio — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════

# ─── Flask Core ──────────────────────────────────────────────────
# Generate a strong random key:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="your-strong-random-secret-key-here"

# ─── Application Environment ─────────────────────────────────────
# Values: "dev" | "test" | "prod"
APP_ENV="dev"

# ─── Database ────────────────────────────────────────────────────
# Dev: leave as default (SQLite). Prod: set to PostgreSQL URL.
# DATABASE_URL="postgresql://user:password@host:5432/linkedin_studio"

# ─── Encryption (REQUIRED for LinkedIn token security) ───────────
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: Changing this key will invalidate all stored LinkedIn tokens.
# Users will need to reconnect LinkedIn if this key changes.
FERNET_KEY="your-fernet-encryption-key-here"

# ─── Google OAuth ────────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs → Credentials
# Authorized redirect URI: http://localhost:5000/auth/callback (dev)
#                          https://yourdomain.com/auth/callback (prod)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Required for local dev only (allows HTTP). Remove in production.
OAUTHLIB_INSECURE_TRANSPORT="1"

# ─── LinkedIn OAuth ──────────────────────────────────────────────
# Create at: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID="your-linkedin-app-client-id"
LINKEDIN_CLIENT_SECRET="your-linkedin-app-client-secret"

# ─── AI (Google Gemini) ──────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key-here"

# ─── Stripe (Payments) ───────────────────────────────────────────
# Test keys for dev, live keys for prod only
STRIPE_PUBLIC_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRO_PRICE_ID="price_..."

# ─── Redis (Rate Limiter + Sessions in Production) ───────────────
# Required in production for multi-process rate limiting.
# Leave unset in dev (falls back to in-memory storage).
# REDIS_URL="redis://localhost:6379"
