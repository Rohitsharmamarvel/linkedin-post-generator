# ──────────────────────────────────────────────────────────────────────────────
# LINKSCALE ENVIRONMENT TEMPLATE (.env.example)
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to '.env' and fill in the values for local development.
# DO NOT commit your real '.env' file to Git!
# ──────────────────────────────────────────────────────────────────────────────

# ─── CORE ───────────────────────────────────────────────────────────────────
FLASK_APP=run.py
FLASK_DEBUG=1
SECRET_KEY=generate_a_random_hex_string_here
APP_ENV=dev

# ─── DATABASE ───────────────────────────────────────────────────────────────
# Local: sqlite:///app.db
# Prod: postgresql://user:pass@host:port/dbname
DATABASE_URL=sqlite:///app.db

# ─── AUTHENTICATION (GOOGLE) ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_METADATA_URL=https://accounts.google.com/.well-known/openid-configuration

# ─── LINKEDIN ───────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_METADATA_URL=https://www.linkedin.com/oauth/.well-known/openid-configuration

# ─── AI (GEMINI) ────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODELS=gemini-2.5-flash,gemini-2.0-flash

# ─── SECURITY ───────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_key_here

# ─── STRIPE ─────────────────────────────────────────────────────────────────
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
